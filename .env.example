# Jina Reader — free web search & scrape (https://jina.ai/reader)
# Optional but recommended for higher rate limits
JINA_API_KEY=

# OpenAI — structures raw crawled content into clean event cards
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase — persistent events, venues, push subscriptions (free tier)
# Run supabase/schema.sql in your project SQL editor
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID) — weekend digest notifications
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Moderation & cron ingest/notify endpoints
MODERATOR_SECRET=
CRON_SECRET=
