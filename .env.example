# OpenAI — structures raw crawled content into clean event cards
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Brave Search — optional web search for ingest (~$5/mo free credits ≈ 1k queries)
# Sign up: https://api-dashboard.search.brave.com/ → Search plan → Add API key
# Test locally: BRAVE_SEARCH_API_KEY=your-key node scripts/test-brave-search.mjs
BRAVE_SEARCH_API_KEY=

# Google Analytics — track page views and user behavior (free)
# 1. Go to https://analytics.google.com/
# 2. Create a new GA4 property for your site
# 3. Copy the Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console — site ownership verification (free)
# 1. Go to https://search.google.com/search-console
# 2. Add property https://pop-event.com → choose "HTML tag" verification
# 3. Copy only the content value from the meta tag (not the full tag)
# See SEARCH_CONSOLE_SETUP.md for full indexing steps
GOOGLE_SITE_VERIFICATION=

# Firebase — persistent events, venues, push subscriptions (Spark/free tier)
# See firebase/README.md for setup
# Option A: paste full service account JSON (easiest on Netlify)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: separate fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Web Push (VAPID) — weekend digest notifications
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Canonical site URL for share links and Open Graph (defaults to https://pop-event.com)
NEXT_PUBLIC_SITE_URL=https://pop-event.com

# Moderation & cron ingest/notify endpoints
MODERATOR_SECRET=
CRON_SECRET=

# Venue assessments — editorial snapshots on venue pages only
# Set to false/0/off to hide. Prefer NEXT_PUBLIC_ so client can hide too.
NEXT_PUBLIC_VENUE_ASSESSMENTS_ENABLED=true
VENUE_ASSESSMENTS_ENABLED=true
# Event opinions — unique researched takes (never copy venue tips onto events)
NEXT_PUBLIC_EVENT_OPINIONS_ENABLED=true
EVENT_OPINIONS_ENABLED=true
# Optional Google Places API (New) key — overlays rating + review sentiment on venue tips
# Also powers Places → event-opinion draft pipeline (cron; approve before live)
# Enable Places API (New) in Google Cloud; leave empty for editorial-only
GOOGLE_PLACES_API_KEY=

# Browser Maps JavaScript API key — in-app Street View modal on venue pages
# Enable Maps JavaScript API; restrict key HTTP referrers to pop-event.com + localhost
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Opinion drafts: GET/POST /api/cron/event-opinion-drafts?secret=CRON_SECRET&generate=1
# Approve: ?secret=&approve=eventId  Reject: ?secret=&reject=eventId
# Approved drafts (with Google ★ rating) appear on events via /api/events/[id]/opinion
