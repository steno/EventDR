# Must stay fresh so clients pick up new service worker / app version.
/sw.js
  Cache-Control: no-store, max-age=0, must-revalidate

/app-version.json
  Cache-Control: no-store, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: no-store, max-age=0, must-revalidate

# PWA icons: short soft-cache (versioned via manifest / app-version polling).
/icons/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Static media — filenames are stable; event/venue URLs also use ?v= for busting.
/events/*
  Cache-Control: public, max-age=31536000, immutable

/venues/*
  Cache-Control: public, max-age=31536000, immutable

/cities/*
  Cache-Control: public, max-age=31536000, immutable

/categories/*
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

/*.svg
